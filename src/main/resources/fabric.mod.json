{
    "schemaVersion": 1,
    "id": "${id}",
    "name": "${name}",
    "version": "${version}",
    "description": "Adds in a load of customization to a few native UI elements such as the bossbar, scoreboard, etc.",
    "authors": [
        "Polyfrost"
    ],
    "contact": {
        "homepage": "https://polyfrost.org",
        "sources": "https://github.com/Polyfrost/VanillaHUD"
    },
    "license": "LGPL-3.0-or-later",
    "environment": "client",
    "entrypoints": {
        "client": [
            {
                "value": "org.polyfrost.vanillahud.VanillaHUDClient",
                "adapter": "kotlin"
            }
        ]
    },
    "mixins": [
        "mixins.vanillahud.json"
    ],
    "depends": {
        "minecraft": "${minecraft}",
        "fabricloader": ">=0.15.11"
    }
}
